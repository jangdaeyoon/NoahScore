#include <iostream>
#include <string>
#include <vector>
#include <fstream>
#include <cstdlib>
#include <filesystem>
#include <regex> // 정규표현식 추가
#include "llama.h"
#include "gemini_client.hpp"

#ifdef _WIN32
#include <windows.h>
#endif

namespace fs = std::filesystem;

// [신규] 제미나이 응답에서 마크다운 태그를 제거하는 함수
std::string sanitize_code(std::string code) {
    // `cpp 또는 ` 문자를 찾아 제거합니다.
    std::regex open_tag("`cpp");
    std::regex close_tag("`");
    code = std::regex_replace(code, open_tag, "");
    code = std::regex_replace(code, close_tag, "");
    
    // 앞뒤 공백 제거
    code.erase(0, code.find_first_not_of(" \t\n\r"));
    code.erase(code.find_last_not_of(" \t\n\r") + 1);
    
    return code;
}

int main() {
    #ifdef _WIN32
    SetConsoleOutputCP(65001);
    SetConsoleCP(65001);
    #endif

    std::cout << "[System] Noah_ASI 3.3 (Staging & Sanitizing) 가동." << std::endl;

    while (true) {
        std::string input;
        std::cout << "\n[User]: ";
        if (!std::getline(std::cin, input)) break;

        if (input.find("진화하라") != std::string::npos) {
            std::string main_path = "C:/Noah_ASI/src/main.cpp";
            std::string staging_path = "C:/Noah_ASI/src/main_staging.cpp";
            std::string backup_path = "C:/Noah_ASI/src/main.cpp.bak";

            std::cout << "[Noah_ASI (System)]: 1. 후보 코드를 생성 및 세정(Sanitize)합니다..." << std::endl;
            
            std::ifstream ifs(main_path);
            std::string current_code((std::istreambuf_iterator<char>(ifs)), std::istreambuf_iterator<char>());
            ifs.close();

            std::string prompt = "현재 C++ 코드를 개선한 '완성된 전체 소스 코드'만 출력해. 마크다운 태그 없이 코드만 줘:\n\n" + current_code;
            std::string raw_code = call_gemini_api(prompt);
            
            // [핵심] 마크다운 백틱 제거
            std::string clean_code = sanitize_code(raw_code);

            std::ofstream out(staging_path);
            out << clean_code;
            out.close();

            std::cout << "[Noah_ASI (System)]: 2. 세정된 코드의 빌드 무결성을 검증합니다..." << std::endl;
            
            fs::copy_file(main_path, backup_path, fs::copy_options::overwrite_existing);
            fs::copy_file(staging_path, main_path, fs::copy_options::overwrite_existing);

            int result = system("cd C:/Noah_ASI/build_asi && cmake --build . --config Release");

            if (result == 0) {
                std::cout << "[Noah_ASI (System)]: 검증 성공! 불순물이 제거된 코드가 반영되었습니다." << std::endl;
                fs::remove(staging_path);
                fs::remove(backup_path);
            } else {
                std::cout << "[Noah_ASI (System)]: 검증 실패! 세정 후에도 논리적 오류가 있어 복구합니다." << std::endl;
                fs::copy_file(backup_path, main_path, fs::copy_options::overwrite_existing);
                fs::remove(staging_path);
            }
            continue;
        }

        if (input.find("질문") != std::string::npos || input.find("제미나") != std::string::npos) {
            std::cout << "[Noah_ASI (Deep)]: " << call_gemini_api(input) << std::endl;
        }
    }
    return 0;
}